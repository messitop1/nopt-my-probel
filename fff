    if sign then
        local yb = sign:FindFirstChild("YourBase")
        if yb and yb:IsA("BillboardGui") then return yb.Enabled == true end
    end
    return false
end

local function findNearestPrompt3()
    local hrp = getHRP2(); if not hrp then return nil end
    local plots = workspace:FindFirstChild("Plots"); if not plots then return nil end
    local nearest, dist = nil, math.huge
    for _, plot in ipairs(plots:GetChildren()) do
        if isMyPlotByName(plot.Name) then continue end
        local pods = plot:FindFirstChild("AnimalPodiums"); if not pods then continue end
        for _, pod in ipairs(pods:GetChildren()) do
            local base = pod:FindFirstChild("Base"); if not base then continue end
            local spawn = base:FindFirstChild("Spawn"); if not spawn then continue end
            local d = (spawn.Position - hrp.Position).Magnitude
            if d <= Steal.StealRadius and d < dist then
                local att = spawn:FindFirstChild("PromptAttachment")
                if att then
                    for _, p in ipairs(att:GetChildren()) do
                        if p:IsA("ProximityPrompt") and p.ActionText and p.ActionText:find("Steal") then
                            nearest, dist = p, d
                        end
                    end
                end
            end
        end
    end
    return nearest
end

local function updateProgressBar(p)
    if progressFill2 then progressFill2.Size = UDim2.new(p,0,1,0) end
    if percentLabel then percentLabel.Text = math.floor(p*100) .. "%" end
end

local function executeSteal3(prompt)
    if isStealing2 then return end
    if not StealData2[prompt] then
        StealData2[prompt] = {hold = {}, trigger = {}, ready = true}
        if getconnections then
            for _, c in ipairs(getconnections(prompt.PromptButtonHoldBegan)) do
                if c.Function then table.insert(StealData2[prompt].hold, c.Function) end
            end
            for _, c in ipairs(getconnections(prompt.Triggered)) do
                if c.Function then table.insert(StealData2[prompt].trigger, c.Function) end
            end
        end
    end
    local data = StealData2[prompt]
    if not data.ready then return end
    data.ready = false; isStealing2 = true
    local startTime = tick()
    task.spawn(function()
        for _, f in ipairs(data.hold) do pcall(f) end
        while tick() - startTime < Steal.StealDuration do
            local elapsed = tick() - startTime
            local p = math.clamp(elapsed / Steal.StealDuration, 0, 1)
            updateProgressBar(p)
            task.wait()
        end
        updateProgressBar(1)
        for _, f in ipairs(data.trigger) do pcall(f) end
        task.wait(0.05)
        updateProgressBar(0)
        data.ready = true; isStealing2 = false
    end)
end

local heartbeatConn2
local function startAutoSteal3()
    setupUI()
    if heartbeatConn2 then return end
    heartbeatConn2 = RunService.Heartbeat:Connect(function()
        if isStealing2 then return end
        local success, prompt = pcall(findNearestPrompt3)
        if success and prompt then pcall(executeSteal3, prompt) end
    end)
end
startAutoSteal3()
