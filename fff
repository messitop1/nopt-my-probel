    if keyRef then
        local chip = Instance.new("TextButton", row)
        chip.Size = UDim2.new(0,CHIP_W,0,CHIP_H)
        chip.Position = UDim2.new(0, lblX, 0.5, -CHIP_H/2)
        chip.BackgroundColor3 = C.chipBg
